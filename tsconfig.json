{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node",
      "vscode"
    ],
    "baseUrl": ".",
    "rootDir": "."
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.mjs"
  ]
}
